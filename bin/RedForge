import sys
import os
import subprocess
import argparse
from pathlib import Path

# Ajouter le chemin du projet
PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, PROJECT_ROOT)


def check_python_version():
    """Vérifie la version de Python"""
    if sys.version_info < (3, 11):
        print("❌ RedForge nécessite Python 3.11 ou supérieur")
        print(f"   Version actuelle: {sys.version_info.major}.{sys.version_info.minor}")
        print("👉 Veuillez installer Python 3.11+")
        sys.exit(1)


def check_venv():
    """Vérifie et active l'environnement virtuel"""
    venv_path = os.path.join(PROJECT_ROOT, "venv")
    
    # Si on est déjà dans un environnement virtuel
    if hasattr(sys, 'real_prefix') or (hasattr(sys, 'base_prefix') and sys.base_prefix != sys.prefix):
        return True
    
    # Vérifier si l'environnement virtuel existe
    if os.path.exists(venv_path):
        python_path = os.path.join(venv_path, "bin", "python")
        if os.path.exists(python_path):
            print("⚠️  Environnement virtuel détecté mais non activé")
            print(f"👉 Veuillez activer l'environnement virtuel:")
            print(f"   source {venv_path}/bin/activate")
            print(f"   python bin/RedForge [options]")
            return False
    
    return True


def check_sudo_for_advanced():
    """Vérifie les droits sudo pour les fonctionnalités avancées"""
    args = sys.argv[1:]
    
    # Options nécessitant les droits root
    advanced_features = {
        'direct': ['-g', '--gui', '--stealth', '--apt'],
        'phases': ['scan', 'exploit', 'all'],
        'ports': ['--ports', '--scan-ports']
    }
    
    # Vérifier les options directes
    for feature in advanced_features['direct']:
        if feature in args:
            if os.geteuid() != 0:
                print("❌ RedForge nécessite les droits sudo pour cette opération")
                print("👉 Veuillez exécuter : sudo RedForge " + " ".join(args))
                sys.exit(1)
            return
    
    # Vérifier les phases dangereuses
    for i, arg in enumerate(args):
        if arg in ['-p', '--phase'] and i + 1 < len(args):
            phase = args[i + 1]
            if phase in advanced_features['phases']:
                if os.geteuid() != 0:
                    print(f"❌ La phase '{phase}' nécessite les droits sudo")
                    print("👉 Veuillez exécuter : sudo RedForge " + " ".join(args))
                    sys.exit(1)


def check_dependencies():
    """Vérifie les dépendances essentielles et les installe si nécessaire"""
    missing = []
    
    # Packages Python essentiels
    required_packages = ['flask', 'requests', 'rich', 'cryptography', 'yaml']
    
    for package in required_packages:
        try:
            __import__(package)
        except ImportError:
            missing.append(package)
    
    if missing:
        print("⚠️  Dépendances Python manquantes: {}".format(', '.join(missing)))
        print("👉 Installation automatique...")
        
        requirements_file = os.path.join(PROJECT_ROOT, "requirements.txt")
        if os.path.exists(requirements_file):
            try:
                subprocess.run(
                    [sys.executable, "-m", "pip", "install", "-r", requirements_file],
                    check=True,
                    capture_output=True
                )
                print("✅ Dépendances installées avec succès")
            except subprocess.CalledProcessError as e:
                print("❌ Erreur lors de l'installation des dépendances")
                print(f"👉 Veuillez exécuter: pip install -r {requirements_file}")
                sys.exit(1)
        else:
            print("❌ Fichier requirements.txt non trouvé")
            sys.exit(1)


def check_tools():
    """Vérifie les outils système essentiels"""
    required_tools = {
        'nmap': 'nmap',
        'sqlmap': 'sqlmap',
        'whatweb': 'whatweb'
    }
    
    optional_tools = {
        'msfconsole': 'metasploit-framework',
        'hydra': 'hydra',
        'dirb': 'dirb'
    }
    
    missing_required = []
    missing_optional = []
    
    import shutil
    for tool in required_tools:
        if not shutil.which(tool):
            missing_required.append(tool)
    
    for tool in optional_tools:
        if not shutil.which(tool):
            missing_optional.append(tool)
    
    if missing_required:
        print("⚠️  Outils requis manquants: {}".format(', '.join(missing_required)))
        print("👉 Installation recommandée: sudo apt install {}".format(' '.join(missing_required)))
    
    if missing_optional:
        print("ℹ️  Outils optionnels manquants: {}".format(', '.join(missing_optional)))
    
    return len(missing_required) == 0


def setup_directories():
    """Crée les répertoires nécessaires"""
    home_dir = Path.home()
    redforge_dir = home_dir / ".RedForge"
    
    directories = [
        redforge_dir,
        redforge_dir / "logs",
        redforge_dir / "reports",
        redforge_dir / "workspace",
        redforge_dir / "sessions",
        redforge_dir / "wordlists",
        redforge_dir / "cache",
        redforge_dir / "profiles"
    ]
    
    for directory in directories:
        directory.mkdir(parents=True, exist_ok=True)
    
    # Créer le fichier de configuration par défaut
    config_file = redforge_dir / "config.json"
    if not config_file.exists():
        import json
        default_config = {
            "version": "1.0.0",
            "language": "fr_FR",
            "theme": "auto",
            "timeout": 300,
            "threads": 10,
            "stealth_mode": False,
            "apt_mode": False,
            "workspace": str(redforge_dir / "workspace"),
            "logs": str(redforge_dir / "logs"),
            "reports": str(redforge_dir / "reports"),
            "api": {
                "enabled": True,
                "port": 5000,
                "host": "127.0.0.1"
            },
            "stealth": {
                "random_delays": True,
                "user_agent_rotation": True,
                "request_jitter": 30,
                "min_delay": 0.5,
                "max_delay": 5.0
            }
        }
        with open(config_file, 'w', encoding='utf-8') as f:
            json.dump(default_config, f, indent=4)
    
    return redforge_dir


