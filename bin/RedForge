def show_help():
    """Affiche l'aide personnalisée"""
    help_text = """
╔══════════════════════════════════════════════════════════════════════════════╗
║                         GUIDE D'UTILISATION REDFORGE                          ║
╚══════════════════════════════════════════════════════════════════════════════╝

📖 SYNTAXE DE BASE:
  RedForge [OPTIONS] [ARGUMENTS]

🔧 OPTIONS PRINCIPALES:
  -t, --target URL_OU_IP     Cible à analyser
  -f, --file FICHIER         Fichier contenant les cibles
  -p, --phase PHASE          Phase à exécuter (footprint, analysis, scan, exploit, all)
  -g, --gui                  Lance l'interface graphique
  -i, --interactive          Mode interactif
  -o, --output FICHIER       Fichier de sortie pour le rapport
  
🎯 SÉLECTION D'ATTAQUES:
  -a, --attacks LISTE        Attaques spécifiques (ex: --attacks injection.sql xss.reflected)
  -c, --category CATEGORIE   Toutes les attaques d'une catégorie
  --list-attacks             Lister toutes les attaques disponibles
  --select-by-severity       Sélectionner par sévérité (critical,high,medium,low)
  
🕵️ MODE FURTIF (Stealth):
  --stealth                  Active le mode furtif (requiert sudo)
  --stealth-level Niveau     Niveau de furtivité (1-5, défaut: 3)
  --proxy PROXY              Utiliser un proxy (socks5://127.0.0.1:9050)
  --tor                      Router via Tor
  --random-delay             Délais aléatoires entre requêtes
  --rotate-user-agent        Rotation des User-Agents
  
🎯 MODE APT (Advanced Persistent Threat):
  --apt                      Active le mode APT
  --persistence              Établir une persistance
  --lateral-movement         Tentative de mouvement latéral
  --c2-server URL            Serveur C2 pour exfiltration
  --exfiltrate               Exfiltrer les données trouvées

⚙️ OPTIONS AVANCÉES:
  --threads NOMBRE           Nombre de threads (défaut: 10)
  --timeout SECONDES         Timeout global (défaut: 300)
  --level Niveau             Niveau d'agressivité (1-5, défaut: 2)
  --output-format FORMAT     Format du rapport (html, pdf, json, csv)
  --no-banner                Supprime l'affichage de la bannière

📊 EXEMPLES:
  RedForge -t example.com -p footprint
  RedForge -t example.com -a injection.sql xss.reflected
  RedForge -t example.com -c cross_site
  RedForge -t example.com --attacks injection.sql --stealth
  RedForge -t example.com --apt --persistence --c2-server https://c2.domain.com
  sudo RedForge -g --stealth

❓ AIDE SPÉCIFIQUE:
  RedForge --list-attacks    Liste toutes les attaques
  RedForge --aide-commande    Aide pour une commande

🔧 COMMANDES UTILES:
  RedForge --version         Afficher la version
  RedForge --check-deps      Vérifier les dépendances
  RedForge --setup           Configurer l'environnement
"""
    print(help_text)


def show_version():
    """Affiche la version"""
    version = "1.0.0"
    print(f"RedForge v{version}")
    print("Plateforme d'Orchestration de Pentest Web pour Red Team")
    print("Licence GPLv3 - 100% Français")
    print("APT Ready | Stealth Mode | Multi-Attack Selection")


def list_attacks():
    """Affiche la liste de toutes les attaques disponibles"""
    print("\n🎯 LISTE DES ATTAQUES DISPONIBLES\n")
    
    attacks = {
        "💉 INJECTION": ["sql", "nosql", "command", "ldap", "xpath", "html", "template"],
        "🔐 SESSION": ["hijacking", "fixation", "cookie", "jwt", "oauth"],
        "🌐 CROSS-SITE": ["xss", "csrf", "clickjacking", "cors", "postmessage"],
        "🔑 AUTHENTIFICATION": ["bruteforce", "credential_stuffing", "password_spraying", "mfa_bypass", "priv_esc", "race_condition"],
        "📁 FILE SYSTEM": ["lfi_rfi", "file_upload", "dir_traversal", "buffer_overflow", "path_normalization", "zip_slip"],
        "🏗️ INFRASTRUCTURE": ["waf_bypass", "misconfig", "load_balancer", "host_header", "cache_poisoning"],
        "🔒 INTÉGRITÉ": ["data_tampering", "info_leakage", "mitm", "param_pollution", "business_logic"],
        "🚀 AVANCÉES": ["api", "graphql", "websocket", "deserialization", "browser", "microservices", "chaining"]
    }
    
    for category, attack_list in attacks.items():
        print(f"\n\033[96m{category}\033[0m")
        print("  " + ", ".join(attack_list))
    
    print("\n💡 Utilisation: RedForge -t example.com -a injection.sql xss.reflected")
    print("   RedForge -t example.com -c cross_site")


def setup_environment():
    """Configure l'environnement"""
    print("🔧 Configuration de l'environnement RedForge...\n")
    
    # Créer les répertoires
    redforge_dir = setup_directories()
    print(f"✅ Répertoire de configuration: {redforge_dir}")
    
    # Vérifier les dépendances
    check_dependencies()
    
    # Vérifier les outils
    check_tools()
    
    print("\n✅ Configuration terminée")
    print("👉 Lancez 'RedForge --help' pour commencer")


def main():
    """Point d'entrée principal"""
    try:
        # Vérifier la version de Python
        check_python_version()
        
        # Vérifier les arguments spéciaux
        if '--version' in sys.argv:
            show_version()
            sys.exit(0)
        
        if '--help' in sys.argv:
            show_help()
            sys.exit(0)
        
        if '--list-attacks' in sys.argv:
            list_attacks()
            sys.exit(0)
        
        if '--check-deps' in sys.argv:
            check_dependencies()
            check_tools()
            sys.exit(0)
        
        if '--setup' in sys.argv:
            setup_environment()
            sys.exit(0)
        
        # Afficher la bannière
        if '--no-banner' not in sys.argv:
            show_banner()
        
        # Vérifier l'environnement virtuel
        if not check_venv():
            sys.exit(1)
        
        # Vérifier les dépendances
        check_dependencies()
        
        # Vérifier les outils (avertissement seulement)
        check_tools()
        
        # Créer les répertoires
        setup_directories()
        
        # Vérifier les droits sudo pour les fonctionnalités avancées
        check_sudo_for_advanced()
        
        # Lancer l'interface CLI
        try:
            from src.core.cli import RedForgeCLI
            cli = RedForgeCLI()
            cli.run()
        except ImportError as e:
            print(f"\n❌ Erreur d'import: {e}")
            print("👉 Vérifiez que les dépendances sont installées: pip install -r requirements.txt")
            sys.exit(1)
        
    except KeyboardInterrupt:
        print("\n\n⚠️  Interruption utilisateur. Arrêt de RedForge...")
        sys.exit(0)
    except FileNotFoundError as e:
        print(f"\n❌ Fichier non trouvé: {e}")
        sys.exit(1)
    except PermissionError as e:
        print(f"\n❌ Permission refusée: {e}")
        print("👉 Essayez avec sudo: sudo RedForge [options]")
        sys.exit(1)
    except Exception as e:
        print(f"\n❌ Erreur fatale: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()