{
    "footprint": {
        "title": "Phase 1: Footprinting - Reconnaissance",
        "description": "Cette phase collecte un maximum d'informations sur la cible sans être intrusif. Elle permet de cartographier la surface d'attaque et d'identifier les services exposés.",
        "discoveries": [
            "Adresses IP et sous-domaines",
            "Services et ports ouverts",
            "Technologies web utilisées (CMS, frameworks, langages)",
            "Serveurs DNS et emails",
            "Certificats SSL/TLS",
            "Firewalls et systèmes de protection",
            "Système d'exploitation distant"
        ],
        "options": {
            "dns_enum": "Énumération DNS complète (enregistrements A, AAAA, MX, TXT, NS, SOA)",
            "subdomains": "Découverte de sous-domaines par brute force",
            "tech_detect": "Détection des technologies (serveur, langages, frameworks)",
            "no_ping": "Ne pas pinguer la cible (évite la détection ICMP)",
            "os_detect": "Détection du système d'exploitation",
            "port_scan": "Scan des ports spécifiques (défaut: 1-1000)",
            "service_version": "Détection des versions des services"
        },
        "examples": [
            "RedForge -t example.com -p footprint",
            "RedForge -t example.com -p footprint --dns-enum --subdomains",
            "RedForge -t 192.168.1.0/24 -p footprint --port-scan",
            "RedForge -f cibles.txt -p footprint --tech-detect --os-detect"
        ],
        "outputs": [
            "~/.RedForge/workspace/footprint_[cible].json",
            "~/.RedForge/workspace/nmap_[cible].xml",
            "~/.RedForge/workspace/subdomains_[cible].txt",
            "~/.RedForge/workspace/dns_[cible].json",
            "~/.RedForge/workspace/technologies_[cible].json"
        ],
        "tools_used": [
            "Nmap - Scan de ports et services",
            "WhatWeb - Détection de technologies",
            "DNSEnum - Énumération DNS",
            "Sublist3r - Découverte de sous-domaines"
        ]
    },
    
    "analysis": {
