            "mssql": ["WAITFOR DELAY '0:0:5'", "@@VERSION", "DB_NAME()", "SYSTEM_USER"],
            "oracle": ["dbms_pipe.receive_message('x',5)", "SELECT version FROM v$instance", "SELECT user FROM dual"]
        },
        "remediation": "Requêtes paramétrées, échappement des entrées, ORM, moindre privilège.",
        "tools": [
            "SQLMap - Injection SQL automatisée",
            "jSQL Injection - Interface graphique",
            "Havij - Injection SQL Windows"
        ]
    },
    
