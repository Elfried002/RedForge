        ],
        "tools_used": [
            "SQLMap - Injection SQL",
            "XSStrike/Dalfox - Cross-Site Scripting",
            "LFISuite - LFI/RFI",
            "SSRFmap - SSRF",
            "XXEinjector - XXE"
        ]
