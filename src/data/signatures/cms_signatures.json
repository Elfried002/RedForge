    "wordpress": {
        "name": "WordPress",
        "description": "CMS le plus populaire au monde, utilisé pour les blogs et sites web",
        "patterns": {
            "headers": [
                "X-Powered-By: WordPress",
                "X-Pingback:.*xmlrpc.php"
            ],
            "html": [
                "wp-content",
                "wp-includes",
                "wp-json",
                "wp-admin",
                "wordpress",
                "/wp-",
                "WordPress",
                "wp-login.php",
                "xmlrpc.php",
                "wp-cron.php",
                "wp-signup.php",
                "wp-activate.php",
                "wp-settings.php",
                "wp-config.php",
                "wp-load.php",
                "wp-blog-header.php",
                "wp-comments-post.php",
                "wp-links-opml.php",
                "wp-trackback.php",
                "generator\" content=\"WordPress"
            ],
            "files": [
                "/wp-login.php",
                "/wp-admin/",
                "/xmlrpc.php",
                "/wp-json/",
                "/wp-content/",
                "/wp-includes/",
