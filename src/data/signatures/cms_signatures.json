        "version_detection": {
            "readme": "/readme.html",
            "generator": "meta[name=\"generator\"]",
            "css_js": "/wp-content/themes/.*/style\\.css\\?ver=([0-9.]+)",
            "feed": "/feed/.*generator/name=WordPress(?:\\/([0-9.]+))?"
