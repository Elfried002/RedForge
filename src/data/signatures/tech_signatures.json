{
    "web_servers": {
        "apache": {
            "name": "Apache HTTP Server",
            "description": "Serveur web open source le plus populaire",
            "patterns": {
                "headers": [
                    "Server: Apache",
                    "Server: Apache/",
                    "X-Powered-By: Apache"
                ],
                "html": [
                    "Apache",
                    "Apache/",
                    "Apache Tomcat",
                    "mod_",
                    ".htaccess"
                ],
                "files": [
                    "/server-status",
                    "/server-info",
                    "/.htaccess",
                    "/.htpasswd",
                    "/cgi-bin/",
                    "/icons/",
                    "/manual/"
                ]
            }
        },
        "nginx": {
            "name": "Nginx",
            "description": "Serveur web haute performance",
            "patterns": {
                "headers": [
                    "Server: nginx",
                    "Server: nginx/",
                    "X-Powered-By: nginx"
                ],
                "html": [
                    "nginx",
                    "nginx/",
                    "nginx-",
                    "nginx_"
                ],
                "files": [
                    "/nginx_status",
                    "/status",
                    "/.well-known/",
                    "/nginx.conf"
                ]
            }
        },
        "iis": {
            "name": "Microsoft IIS",
            "description": "Serveur web Microsoft",
            "patterns": {
                "headers": [
                    "Server: Microsoft-IIS",
                    "Server: IIS",
                    "X-Powered-By: ASP.NET"
                ],
                "html": [
                    "IIS",
                    "Internet Information Services",
                    "ASP.NET",
                    ".aspx",
                    ".ashx",
                    ".asmx"
                ],
                "files": [
                    "/iisstart.htm",
                    "/iisstart.png",
                    "/web.config",
                    "/aspnet_client/",
                    "/Trace.axd",
                    "/elmah.axd"
                ]
            }
        },
        "tomcat": {
            "name": "Apache Tomcat",
            "description": "Serveur d'applications Java",
            "patterns": {
                "headers": [
                    "Server: Apache-Coyote",
                    "Server: Tomcat"
                ],
                "html": [
                    "Tomcat",
                    "Apache Tomcat",
                    "Catalina",
                    "JSP",
                    ".jsp",
                    ".jspx"
                ],
                "files": [
                    "/manager/html",
                    "/host-manager/html",
                    "/examples/",
                    "/docs/",
                    "/tomcat.png",
                    "/favicon.ico"
                ]
            }
        },
        "nodejs": {
            "name": "Node.js",
            "description": "Environnement JavaScript côté serveur",
            "patterns": {
                "headers": [
                    "X-Powered-By: Express",
                    "Server: Node.js"
                ],
                "html": [
                    "Node.js",
                    "Express",
                    "socket.io",
                    "node_modules"
                ],
                "files": [
                    "/package.json",
                    "/node_modules/",
                    "/server.js",
                    "/app.js",
                    "/index.js"
                ]
            }
        },
        "gunicorn": {
            "name": "Gunicorn",
            "description": "Serveur WSGI Python",
            "patterns": {
                "headers": [
                    "Server: gunicorn"
                ],
                "html": [
                    "gunicorn"
                ]
            }
