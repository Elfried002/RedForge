    "cdn_security": {
        "cloudflare": {
            "name": "Cloudflare",
            "description": "CDN et protection DDoS",
            "patterns": {
                "headers": [
                    "CF-Ray",
                    "CF-Cache-Status",
                    "Cloudflare",
                    "__cfduid",
                    "cf-",
                    "CF-RAY",
                    "CF-Cache-Status",
                    "CF-Cloudflare",
                    "CF-Worker"
                ],
                "html": [
                    "cloudflare",
                    "Cloudflare",
                    "cdn-cgi",
                    "__cf_chl",
                    "__cf_bm",
                    "__cfruid"
                ],
                "files": [
                    "/cdn-cgi/",
                    "/cdn-cgi/trace",
                    "/cdn-cgi/challenge-platform",
                    "/cdn-cgi/scripts/",
                    "/cdn-cgi/styles/",
                    "/cdn-cgi/images/"
                ]
            }
        },
        "akamai": {
            "name": "Akamai",
            "description": "CDN et sécurité web",
            "patterns": {
                "headers": [
                    "X-Akamai-",
                    "X-EdgeConnect",
                    "Akamai",
                    "X-Akamai-Transformed",
                    "X-Akamai-Request-ID",
                    "X-Akamai-Edge",
                    "X-Akamai-Session"
                ]
            }
        },
        "aws_cloudfront": {
            "name": "AWS CloudFront",
            "description": "CDN Amazon",
            "patterns": {
                "headers": [
                    "X-Amz-Cf-Id",
                    "CloudFront",
                    "X-Cache",
                    "X-Amz-Cf-Pop",
                    "X-Amz-Edge",
                    "X-Amz-Request-ID"
                ],
                "html": [
                    "cloudfront.net",
                    "cloudfront-"
                ]
            }
        },
        "fastly": {
            "name": "Fastly",
            "description": "CDN et edge cloud",
            "patterns": {
                "headers": [
                    "X-Served-By",
                    "X-Cache-Hits",
                    "Fastly",
                    "X-Squid-Error",
                    "X-Fastly-Request-ID"
                ]
            }
        },
        "incapsula": {
            "name": "Imperva Incapsula",
            "description": "WAF et CDN",
            "patterns": {
                "headers": [
                    "X-CIS",
                    "X-Iinfo",
                    "Incapsula",
                    "X-Forwarded-For",
                    "X-Forwarded-Proto"
                ]
            }
        },
        "sucuri": {
            "name": "Sucuri",
            "description": "WAF et sécurité",
            "patterns": {
                "headers": [
                    "X-Sucuri-ID",
                    "X-Sucuri-Cache",
                    "Sucuri",
                    "X-Sucuri-Block"
                ]
            }
        },
        "modsecurity": {
            "name": "ModSecurity",
            "description": "WAF open source",
            "patterns": {
                "headers": [
                    "Mod_Security",
                    "ModSecurity",
                    "X-Mod-Security"
                ],
                "html": [
                    "ModSecurity",
                    "This error was generated by Mod_Security",
                    "ModSecurity Action"
                ]
            }
        }
    },
