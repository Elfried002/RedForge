{
    "cloudflare": {
        "name": "Cloudflare WAF",
        "description": "Cloudflare Web Application Firewall avec protection DDoS",
        "vendor": "Cloudflare, Inc.",
        "detection": {
            "headers": [
                "CF-Ray",
                "CF-Cache-Status",
                "__cfduid",
                "cf-",
                "Cloudflare",
                "CF-RAY"
            ],
            "html": [
                "cloudflare",
                "Cloudflare Ray ID",
                "Attention Required! | Cloudflare",
                "The owner of this website has banned your access",
                "Please complete the security check",
                "Checking your browser before accessing",
                "DDoS protection by Cloudflare",
                "Performance & security by Cloudflare",
                "This website is using a security service to protect itself from online attacks",
                "Enable JavaScript and cookies to continue"
            ],
            "status_codes": [403, 503],
            "response_time": "slow"
        },
        "bypass_techniques": [
            "Use origin IP address if available",
            "Exploit Cloudflare Workers vulnerabilities",
            "Cache poisoning techniques",
            "Use Tor exit nodes",
            "Use IP rotation",
            "Exploit rate limiting bypasses",
            "Use HTTP request smuggling",
            "Use encoding techniques (UTF-16, UTF-32)",
            "Use fragmented payloads",
            "Use parameter pollution"
        ]
    },
    "aws_waf": {
        "name": "AWS WAF",
        "description": "Amazon Web Services Web Application Firewall",
        "vendor": "Amazon Web Services",
        "detection": {
            "headers": [
                "x-amzn-RequestId",
                "x-amzn-ErrorType",
                "AWSALB",
                "AWSALBTG",
                "x-amzn-WAF",
                "AWS-WAF"
            ],
            "html": [
                "AWS WAF",
                "Request blocked by AWS WAF",
                "AWS WAF has blocked this request",
                "403 Forbidden - AWS WAF"
            ],
            "status_codes": [403, 400],
            "response_time": "normal"
        },
        "bypass_techniques": [
            "Exploit request size limitations",
            "Use IP whitelist bypass if available",
            "Use JSON/XML parsing inconsistencies",
            "Use parameter pollution",
            "Use encoding variations",
            "Use rate limiting bypass",
            "Use AWS region-specific bypasses"
        ]
    },
    "modsecurity": {
        "name": "ModSecurity",
        "description": "Open source Web Application Firewall",
        "vendor": "Trustwave",
        "detection": {
            "headers": [
                "Mod_Security",
                "ModSecurity",
                "X-Mod-Security"
            ],
            "html": [
                "ModSecurity",
                "This error was generated by Mod_Security",
                "ModSecurity Action",
                "Access denied with code 403",
                "ModSecurity: Access denied",
                "ModSecurity: Request rejected",
                "ModSecurity: Method not allowed",
                "ModSecurity: Response denied",
                "ModSecurity: Audit log"
            ],
            "status_codes": [403, 406, 501],
            "response_time": "normal"
        },
        "bypass_techniques": [
            "Use case manipulation",
            "Use double URL encoding",
            "Use tab characters as separators",
            "Use SQL comments /*!50000*/",
            "Use HTML comments <!-- -->",
            "Use line breaks in payloads",
            "Use null byte injection",
            "Use HTTP parameter pollution",
            "Use chunked transfer encoding",
            "Use protocol-level evasion"
        ]
    },
